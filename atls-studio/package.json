{
  "name": "atls-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:atls-rs": "cd ../atls-rs && cargo test",
    "test:all": "vitest run && cd src-tauri && cargo test && cd ../../atls-rs && cargo test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:gaps": "tsx scripts/list-coverage-gaps.ts",
    "test:coverage:report": "npm run test:coverage && npm run test:coverage:gaps",
    "test:e2e": "playwright test",
    "test:validation-fixes": "cd src-tauri && cargo test path_utils --no-fail-fast && cargo test refactor_engine --no-fail-fast",
    "models:fetch": "tsx scripts/fetch-models.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0",
    "tailwindcss": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@playwright/test": "^1.49.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.7",
    "happy-dom": "^15.11.0",
    "monaco-editor": "^0.55.1",
    "tsx": "^4.19.0",
    "typescript": "~5.8.3",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
